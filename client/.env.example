# ─── API URL ──────────────────────────────────────────
# Leave empty for same-origin (when served from the same domain in production)
# or set to your backend URL if front/back are on different domains
VITE_API_URL=

# ─── Stripe (Frontend) ────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key